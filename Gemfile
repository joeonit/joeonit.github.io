source "https://rubygems.org"

# Matches the gems GitHub Pages uses to build your site, so a local
# preview looks the same as production. Only needed if you want to run
# the site locally with `bundle exec jekyll serve`.
gem "github-pages", group: :jekyll_plugins

# Plugins
gem "jekyll-feed"
gem "jekyll-seo-tag"

# Required for local preview on Ruby 3.0+
gem "webrick"
